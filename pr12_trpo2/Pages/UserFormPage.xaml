<Page x:Class="pr12_trpo2.Pages.UserFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr12_trpo2.Pages"
      xmlns:validators="clr-namespace:pr12_trpo2.ValidationRules"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      x:Name="UserFormPageRoot"
      Title="UserFormPage">
    <Page.Resources>
        <Style TargetType="Button" x:Key="ButtonStyle" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="300"/>
        </Style>

        <Style TargetType="TextBox" x:Key="TBoxStyle" BasedOn="{StaticResource MaterialDesignTextBox}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="400"/>
            <Setter Property="Validation.ErrorTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <AdornedElementPlaceholder/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DatePicker" x:Key="DateStyle" BasedOn="{StaticResource MaterialDesignDatePicker}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Validation.ErrorTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <AdornedElementPlaceholder/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Label" x:Key="LabelStyle" BasedOn="{StaticResource MaterialDesignLabel}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
    </Page.Resources>
    
    <Grid>
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Center">
                <StackPanel>
                    <Label Style="{StaticResource LabelStyle}">Логин</Label>
                    <TextBox x:Name="loginTBox" Style="{StaticResource TBoxStyle}">
                        <TextBox.Text>
                            <Binding Path="Login" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <validators:LoginValidation/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <ItemsControl Foreground="Red" FontSize="12" ItemsSource="{Binding ElementName=loginTBox, Path=(Validation.Errors)}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel>
                    <Label Style="{StaticResource LabelStyle}">Имя</Label>
                    <TextBox x:Name="nameTBox" Style="{StaticResource TBoxStyle}">
                        <TextBox.Text>
                            <Binding Path="Name" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <validators:NameValidation/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <ItemsControl Foreground="Red" FontSize="12" ItemsSource="{Binding ElementName=nameTBox, Path=(Validation.Errors)}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel>
                    <Label Style="{StaticResource LabelStyle}">Электронная почта</Label>
                    <TextBox x:Name="emailTBox" Style="{StaticResource TBoxStyle}">
                        <TextBox.Text>
                            <Binding Path="Email" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <validators:EmailValidation/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <ItemsControl Foreground="Red" FontSize="12" ItemsSource="{Binding ElementName=emailTBox, Path=(Validation.Errors)}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel>
                    <Label Style="{StaticResource LabelStyle}">Пароль</Label>
                    <TextBox x:Name="passTBox" Style="{StaticResource TBoxStyle}">
                        <TextBox.Text>
                            <Binding Path="Password" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <validators:PasswordValidation/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <ItemsControl Foreground="Red" FontSize="12" ItemsSource="{Binding ElementName=passTBox, Path=(Validation.Errors)}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel>
                    <Label Style="{StaticResource LabelStyle}">Дата создания</Label>
                    <DatePicker x:Name="dateTBox" Style="{StaticResource DateStyle}">
                        <DatePicker.SelectedDate>
                            <Binding Path="CreatedAt" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <validators:CreatedAtValidation/>
                                </Binding.ValidationRules>
                            </Binding>
                        </DatePicker.SelectedDate>
                    </DatePicker>
                    <ItemsControl Foreground="Red" FontSize="12" ItemsSource="{Binding ElementName=dateTBox, Path=(Validation.Errors)}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel>
                    <Button Click="AddBtn_Click" Style="{StaticResource ButtonStyle}">Сохранить в БД</Button>
                    <Button Click="BackBtn_Click" Style="{StaticResource ButtonStyle}">Назад</Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
